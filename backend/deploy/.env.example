# Ingestion demo env file for `backend/deploy/docker-compose.yml`.
#
# Copy to `backend/deploy/.env` on your VM (do not commit `.env`).

# Shared logging level for collector-api and raw-writer
LOG_LEVEL=INFO

# NATS JetStream
NATS_URL=nats://nats:4222
NATS_STREAM=EVENTS
NATS_SUBJECT_PREFIX=events
NATS_STREAM_MAX_AGE_SECONDS=604800
NATS_DUPLICATE_WINDOW_SECONDS=600

# Collector API
PORT=8080
MAX_EVENTS_PER_REQUEST=500
MAX_REQUEST_BYTES=1048576
COLLECTOR_API_KEYS_JSON={"dev-api-key":"com.example.app"}
IP_HASH_SALT=change_me
STORE_RAW_IP=0
GEOIP_ENABLED=1
GEOIP_MMDB_PATH=/var/lib/geoip/dbip-country-lite.mmdb
CORS_ALLOW_ORIGINS=
CORS_ALLOW_METHODS=POST,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=0
CORS_MAX_AGE_SECONDS=600

# Raw writer
NATS_CONSUMER=raw-writer
NATS_FETCH_BATCH=200
NATS_FETCH_TIMEOUT_SECONDS=1
NATS_ACK_WAIT_SECONDS=120
NATS_MAX_DELIVER=10
RAW_FLUSH_INTERVAL_SECONDS=900
RAW_MAX_EVENTS_PER_FILE=10000
RAW_MAX_BYTES_PER_FILE=52428800

# Raw storage backend selector (gcs|s3)
RAW_STORAGE_BACKEND=gcs
# - gcs mode requires: GCS_RAW_BUCKET
# - s3 mode requires: S3_ENDPOINT_URL, S3_BUCKET, S3_ACCESS_KEY, S3_SECRET_KEY

# GCS
GCS_RAW_BUCKET=example-bucket-name
GCS_RAW_PREFIX=raw

# If VM running outside GCP and using a service account JSON key, mount it and set:
#
# Example for `backend/deploy/docker-compose.yml`:
# - mount: /home/deploy/gcp-sa.json -> /var/secrets/gcp/sa.json
# - set:   GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/gcp/sa.json
GOOGLE_APPLICATION_CREDENTIALS=

# S3-compatible object storage (for SeaweedFS and similar)
# Example SeaweedFS endpoint: http://seaweedfs:8333
S3_ENDPOINT_URL=
S3_BUCKET=
S3_PREFIX=raw
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=1
# SeaweedFS, the safe default is 1
# Meaning URLs look like:
# http://seaweed-host:8333/my-bucket/file.parquet
S3_USE_SSL=0
S3_VERIFY_SSL=0
