# Rawbbit ClickHouse MCP standalone deployment env.
#
# Copy to `.env` on the VM and fill in real values. Do not commit `.env`.

LOG_LEVEL=INFO

# Public hostnames for Caddy automatic HTTPS.
# Use separate hostnames for MCP and Metabase.
MCP_DOMAIN=mcp.example.com
METABASE_DOMAIN=metabase.example.com

# MCP HTTP endpoint path exposed through Caddy.
MCP_PATH=/mcp

# Optional localhost bind ports for host-level reverse proxies or local validation.
MCP_BIND_HOST_PORT=8000
METABASE_BIND_HOST_PORT=3000

# ClickHouse connection.
# If ClickHouse is reachable through HTTPS behind Caddy on another VM, use its public/private hostname,
# port 443, and set CLICKHOUSE_SECURE=1.
# If ClickHouse is on the same VM, use a host/IP/port that is actually reachable from the MCP container.
# On Docker Desktop this may be host.docker.internal; on Linux, loopback-only host bindings are often not reachable from containers.
CLICKHOUSE_HOST=clickhouse.example.com
CLICKHOUSE_PORT=443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_TABLE=events
CLICKHOUSE_SECURE=1
CLICKHOUSE_VERIFY=1

# Query guardrails.
MCP_MAX_QUERY_ROWS=500
MCP_MAX_SAMPLE_ROWS=50
MCP_MAX_EXECUTION_SECONDS=30
MCP_BOT_USER_AGENT_REGEX=bot|spider|crawler|headless|bytespider|ahrefs|googlebot

# Self-hosted static bearer tokens for MCP.
# Leave blank until you generate real values.
# Shape example: {"user1":"long-random-token","user2":"another-long-random-token"}
MCP_API_KEYS_JSON=

# Optional future JWT/JWKS auth integration.
MCP_JWT_PUBLIC_KEY=
MCP_JWT_JWKS_URI=
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=

# Metabase application database and app settings.
POSTGRES_DB=metabase
POSTGRES_USER=metabase
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD
METABASE_TIMEZONE=UTC

# Optional image override if publishing instead of building locally.
MCP_SERVER_IMAGE=rawbbit-clickhouse-mcp:local
