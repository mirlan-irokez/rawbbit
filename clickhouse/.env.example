CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=PASTE_STRONG_PASSWORD_HERE
CLICKHOUSE_DB=default
CLICKHOUSE_HOST=ch.example.com

# Optional: hourly raw Parquet loader into ClickHouse.
# Base URL should point to the S3 storage raw prefix, without the app_id/hour glob.
CLICKHOUSE_RAW_S3_BASE_URL=https://s3.example.com/your-bucket/raw
CLICKHOUSE_RAW_S3_ACCESS_KEY=your-access-key
CLICKHOUSE_RAW_S3_SECRET_KEY=your-secret-key
