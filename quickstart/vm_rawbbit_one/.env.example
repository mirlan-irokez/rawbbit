# Rawbbit one-VM quickstart environment.
#
# Copy this file to `.env` and replace all `change_me` values before running
# the stack. Do not commit `.env`.

# Public hostnames served by Caddy.
COLLECTOR_PUBLIC_HOSTNAME=collector.example.com
S3_PUBLIC_HOSTNAME=s3.example.com

# Shared logging level for collector-api and raw-writer.
LOG_LEVEL=INFO

# NATS JetStream.
NATS_URL=nats://nats:4222
NATS_STREAM=EVENTS
NATS_SUBJECT_PREFIX=events
NATS_STREAM_MAX_AGE_SECONDS=86400
NATS_DUPLICATE_WINDOW_SECONDS=600

# Collector API.
PORT=8080
MAX_EVENTS_PER_REQUEST=500
MAX_REQUEST_BYTES=1048576
COLLECTOR_API_KEYS_JSON={"change_me_api_key":"com.example.app"}
IP_HASH_SALT=change_me
STORE_RAW_IP=0

# GeoIP is disabled by default because the MaxMind/DB-IP database is not
# committed into this quickstart. See geoip/README.md to enable it.
GEOIP_ENABLED=0
GEOIP_MMDB_PATH=/var/lib/geoip/dbip-country-lite.mmdb

CORS_ALLOW_ORIGINS=
CORS_ALLOW_METHODS=POST,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=0
CORS_MAX_AGE_SECONDS=600

# Raw writer.
NATS_CONSUMER=raw-writer
NATS_FETCH_BATCH=200
NATS_FETCH_TIMEOUT_SECONDS=1
NATS_ACK_WAIT_SECONDS=300
NATS_MAX_DELIVER=10
RAW_FLUSH_INTERVAL_SECONDS=60
RAW_MAX_EVENTS_PER_FILE=10000
RAW_MAX_BYTES_PER_FILE=52428800

# Raw storage backend selector (gcs|s3). This quickstart defaults to SeaweedFS S3.
RAW_STORAGE_BACKEND=s3

# GCS settings are kept for compatibility with the deploy reference, but are
# unused when RAW_STORAGE_BACKEND=s3.
GCS_RAW_BUCKET=
GCS_RAW_PREFIX=raw
GOOGLE_APPLICATION_CREDENTIALS=

# S3-compatible object storage.
#
# Inside this Compose stack, raw-writer should use the internal Docker endpoint.
# For ClickHouse or analyst machines outside Docker, use the public Caddy URL:
#   S3_ENDPOINT_URL=https://s3.example.com
#   S3_USE_SSL=1
#   S3_VERIFY_SSL=1
S3_ENDPOINT_URL=http://seaweed-s3:8333

# Fresh mode default:
S3_BUCKET=rawbbit_raw
# Migration mode from the old VM likely wants:
# S3_BUCKET=dataquery-raw

S3_PREFIX=raw
S3_ACCESS_KEY=change_me_access_key
S3_SECRET_KEY=change_me_secret_key

# For SeaweedFS this is an S3 client/signing compatibility value, not the VM's
# physical region.
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=1
S3_USE_SSL=1
S3_VERIFY_SSL=1

# SeaweedFS volume sizing.
#
# This is the max size of each internal SeaweedFS volume file. It is not a
# total disk quota.
SEAWEED_VOLUME_SIZE_LIMIT_MB=5000

# 0 means SeaweedFS auto-calculates volume count from free disk space and
# volume size.
SEAWEED_VOLUME_MAX=0

# Reserve free disk space on the volume server path.
SEAWEED_VOLUME_MIN_FREE_SPACE_GB=5
