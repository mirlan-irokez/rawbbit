# Rawbbit two-VM quickstart environment.
#
# Copy this file to `.env` and replace all `change_me` values before running
# the stack. Do not commit `.env`.

# Public hostnames served by the bundled Caddy container.
MCP_PUBLIC_HOSTNAME=mcp.example.com
METABASE_PUBLIC_HOSTNAME=metabase.example.com
CLICKHOUSE_PUBLIC_HOSTNAME=clickhouse.example.com

LOG_LEVEL=INFO

# ClickHouse bootstrap/admin access. Use only for first-run initialization,
# trusted operator work, and IDE access through SSH tunnel or HTTPS.
CLICKHOUSE_ADMIN_USER=admin
CLICKHOUSE_ADMIN_PASSWORD=change_me_clickhouse_admin_password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_TABLE=events

# ClickHouse resource profile files mounted by Compose.
# Defaults are tuned for the original low-memory VM. For 8 vCPU / 32 GB RAM,
# use production-small.xml and production-small-users.xml. For 8 vCPU / 64 GB
# RAM, use production-medium.xml and production-medium-users.xml.
CLICKHOUSE_CONFIG_PROFILE_FILE=low-memory.xml
CLICKHOUSE_USERS_PROFILE_FILE=low-memory-users.xml

# ClickHouse service users created by clickhouse/initdb.d/02_service_users.sh.
CLICKHOUSE_MCP_USER=rawbbit_mcp
CLICKHOUSE_MCP_PASSWORD=change_me_clickhouse_mcp_password
CLICKHOUSE_METABASE_USER=metabase_reader
CLICKHOUSE_METABASE_PASSWORD=change_me_clickhouse_metabase_password
CLICKHOUSE_LOADER_USER=rawbbit_loader
CLICKHOUSE_LOADER_PASSWORD=change_me_clickhouse_loader_password

# MCP ClickHouse connection. In this quickstart MCP uses the internal Docker
# service name, not the public VM hostname.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_SECURE=0
CLICKHOUSE_VERIFY=1

# Optional localhost bind ports for SSH tunnels or host-level validation.
CLICKHOUSE_HTTP_BIND_HOST_PORT=8123
CLICKHOUSE_NATIVE_BIND_HOST_PORT=9000
MCP_BIND_HOST_PORT=8000
METABASE_BIND_HOST_PORT=3000

# MCP endpoint and query guardrails.
MCP_PATH=/mcp
MCP_MAX_QUERY_ROWS=500
MCP_MAX_SAMPLE_ROWS=50
MCP_MAX_EXECUTION_SECONDS=30
MCP_BOT_USER_AGENT_REGEX='bot|spider|crawler|headless|bytespider|ahrefs|googlebot'

# Public MCP deployments must use auth. Shape example:
# MCP_API_KEYS_JSON='{"mirlan":"long-random-token"}'
MCP_API_KEYS_JSON=
MCP_ALLOW_UNAUTHENTICATED=0

# Optional future JWT/JWKS auth integration.
MCP_JWT_PUBLIC_KEY=
MCP_JWT_JWKS_URI=
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=

# Postgres bootstrap/superuser access. The service is deployed by Compose, but
# durable data is stored in /srv/rawbbit-two/postgres on the VM.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change_me_postgres_superuser_password

# Metabase application database user created by postgres/initdb.d.
METABASE_DB_NAME=metabase
METABASE_DB_USER=metabase_app
METABASE_DB_PASSWORD=change_me_metabase_db_password
METABASE_TIMEZONE=UTC

# Optional hourly raw Parquet loader into ClickHouse.
# Keep endpoint, bucket, and raw prefix separate; the loader joins them.
CLICKHOUSE_RAW_S3_ACCESS_KEY=change_me_reader_access_key
CLICKHOUSE_RAW_S3_SECRET_KEY=change_me_reader_secret_key
CLICKHOUSE_SEAWEED_S3_ENDPOINT=https://s3.example.com
CLICKHOUSE_RAW_S3_BUCKET=rawbbit_raw
CLICKHOUSE_RAW_S3_PREFIX=raw
